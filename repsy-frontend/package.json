{
  "name": "repsy-os-frontend",
  "version": "2.0.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "scripts": {
    "ng": "ng",
    "prestart": "node set-env.js",
    "start": "ng serve",
    "build": "node set-env.js && ng build",
    "build:prod": "node set-env.js && ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint-fix": "ng lint --fix",
    "lint": "ng lint",
    "format": "prettier --write \"src/**/*.{ts,html,css,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css,scss}\"",
    "vercel-build": "pnpm run build:prod"
  },
  "dependencies": {
    "@angular/animations": "^21.0.6",
    "@angular/cdk": "^21.0.5",
    "@angular/common": "^21.0.6",
    "@angular/compiler": "^21.0.6",
    "@angular/core": "^21.0.6",
    "@angular/forms": "^21.0.6",
    "@angular/platform-browser": "^21.0.6",
    "@angular/platform-browser-dynamic": "^21.0.6",
    "@angular/router": "^21.0.6",
    "@eslint/js": "^9.39.2",
    "@ngx-env/builder": "^21.0.1",
    "@stripe/stripe-js": "^8.6.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/chart.js": "^4.0.1",
    "chart.js": "^4.5.1",
    "dotenv": "^17.2.3",
    "dotenv-expand": "^12.0.3",
    "github-markdown-css": "^5.8.1",
    "highlight.js": "^11.11.1",
    "jwt-decode": "^4.0.0",
    "md5": "^2.3.0",
    "moment": "^2.30.1",
    "ngx-highlightjs": "^14.0.1",
    "ngx-markdown": "^21.0.1",
    "postcss": "^8.5.6",
    "remixicon": "^4.8.0",
    "rxjs": "~7.8.2",
    "showdown": "^2.1.0",
    "showdown-highlight": "^3.1.0",
    "ts-md5": "^2.0.1",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.1.0",
    "@angular-eslint/eslint-plugin": "^21.1.0",
    "@angular-eslint/eslint-plugin-template": "^21.1.0",
    "@angular/build": "^21.0.4",
    "@angular/cli": "^21.0.4",
    "@angular/compiler-cli": "^21.0.6",
    "@tailwindcss/nesting": "0.0.0-insiders.565cd3e",
    "@types/jasmine": "~5.1.13",
    "@types/md5": "^2.3.6",
    "@types/node": "^25.0.3",
    "@types/showdown": "^2.0.6",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "angular-eslint": "^21.1.0",
    "autoprefixer": "^10.4.23",
    "daisyui": "^5.5.14",
    "depcheck": "^1.4.7",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jasmine-core": "~5.13.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.51.0"
  }
}
